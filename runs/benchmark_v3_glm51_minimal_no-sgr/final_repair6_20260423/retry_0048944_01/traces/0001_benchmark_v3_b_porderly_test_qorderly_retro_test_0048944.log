ination: C=O + H2N -> CH-NH + H2O\n    # So precursor C17H20N2O2 -> target C17H22N2O + H2O\n    # That doesn't balance... let me check\n    \n    # Actually, reductive amination:\n    # R2C=O + H2N-R' -> R2CH-NH-R' (with reducing agent like NaBH3CN)\n    # So: C17H20N2O2 + [H] -> C17H22N2O + H2O? No...\n    # R2C=O + H2N-R' -> R2C=N-R' (imine) -> R2CH-NH-R' (reduction)\n    # Net: C=O + H2N-R' + 2[H] -> CH-NH-R' + H2O\n    \n    # Precursor: C17H20N2O2\n    # After reductive amination: lose O, gain 2H, form N-C bond\n    # C17H20N2O2 - O + 2H = C17H22N2O\n    # Target: C17H22N2O? Let me check\n    \nelse:\n    print('Precursor invalid!')\n    # Try without stereochemistry\n    precursor2 = Chem.MolFromSmiles('CNCCOC1c2cccc3[nH]cc(c23)CC1=O')\n    if precursor2:\n        print('Non-stereo precursor valid:', Chem.MolToSmiles(precursor2))\n        print('Formula:', rdMolDescriptors.CalcMolFormula(precursor2))\n"})<tool_call>chem_python_tool({"code": "from rdkit import Chem\nfrom rdkit.Chem import rdMolDescriptors\n\n# Check formulas\ntarget = Chem.MolFromSmiles('CN1CCO[C@@H]2c3cccc4[nH]cc(c34)C[C@H]21')\nprecursor = Chem.MolFromSmiles('CNCCO[C@@H]1c2cccc3[nH]cc(c23)CC1=O')\n\nprint('Target formula:', rdMolDescriptors.CalcMolFormula(target))\nprint('Precursor formula:', rdMolDescriptors.CalcMolFormula(precursor))\n\n# Reductive amination: C=O + H2N -> CH-NH + H2O\n# So precursor (with C=O and H2N) -> target (with CH-NH) + H2O\n# C17H20N2O2 -> C17H22N2O + H2O\n# C17H20N2O2 = C17H22N2O + H2O? \n# C17H22N2O + H2O = C17H24N2O2... no that's wrong\n\n# Let me just count atoms\ntarget_atoms = {}\nfor atom in target.GetAtoms():\n    sym = atom.GetSymbol()\n    target_atoms[sym] = target_atoms.get(sym, 0) + 1\nprint('Target atoms:', target_atoms)\n\nprecursor_atoms = {}\nfor atom in precursor.GetAtoms():\n    sym = atom.GetSymbol()\n    precursor_atoms[sym] = precursor_atoms.get(sym, 0) + 1\nprint('Precursor atoms:', precursor_atoms)\n\n# The difference should be: precursor has 